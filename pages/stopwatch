<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Stop Watch | LifeCount</title>
    <link rel="stylesheet" href="../styles.css">
    <style>
        .stopwatch-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex-grow: 1;
            margin-top: 3rem;
            margin-bottom: 3rem;
        }
        .time-display {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 4rem;
            color: var(--primary-color);
            font-weight: 300;
        }
        .colon {
            color: var(--primary-color);
            margin-top: -10px; /* Aligns colon visually */
        }
        .time-segment {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 80px;
        }
        .time-label {
            font-size: 0.9rem;
            color: #888;
            margin-top: 5px;
            font-weight: normal;
        }
        .controls {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 100%;
        }
        /* Extra reset button to make it functional for daily use */
        .reset-btn {
            background-color: transparent;
            color: var(--text-color);
            border: 2px solid var(--card-border);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            box-sizing: border-box;
            text-align: center;
            display: none; /* Hidden until timer is paused */
        }
    </style>
</head>
<body style="display: flex; flex-direction: column; min-height: 100vh;">
    <header class="top-bar">
        <a href="time-menu.html" class="back-btn" aria-label="Go back">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            Back
        </a>
        <h1>Stop Watch</h1>
        <button id="theme-toggle" style="background:none; border:none; font-size:1.5rem; padding: 0; cursor: pointer;">🌗</button>
    </header>

    <main class="page-content" style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
        
        <div class="stopwatch-container">
            <div class="time-display">
                <div class="time-segment">
                    <span id="sw-hours">00</span>
                    <span class="time-label">hours</span>
                </div>
                <span class="colon">:</span>
                <div class="time-segment">
                    <span id="sw-minutes">00</span>
                    <span class="time-label">minutes</span>
                </div>
                <span class="colon">:</span>
                <div class="time-segment">
                    <span id="sw-seconds">00</span>
                    <span class="time-label">seconds</span>
                </div>
            </div>
        </div>

        <div class="controls">
            <button class="primary-btn" id="start-stop-btn">▷ START</button>
            <button class="reset-btn" id="reset-btn">↺ RESET</button>
        </div>
    </main>

    <script src="../app.js"></script>
    <script>
        let timerInterval = null;
        let totalSeconds = 0;
        let isRunning = false;

        const hoursDisplay = document.getElementById('sw-hours');
        const minutesDisplay = document.getElementById('sw-minutes');
        const secondsDisplay = document.getElementById('sw-seconds');
        const startStopBtn = document.getElementById('start-stop-btn');
        const resetBtn = document.getElementById('reset-btn');

        function updateDisplay() {
            const h = Math.floor(totalSeconds / 3600);
            const m = Math.floor((totalSeconds % 3600) / 60);
            const s = totalSeconds % 60;

            hoursDisplay.textContent = h.toString().padStart(2, '0');
            minutesDisplay.textContent = m.toString().padStart(2, '0');
            secondsDisplay.textContent = s.toString().padStart(2, '0');
        }

        function toggleTimer() {
            if (isRunning) {
                // Pause Timer
                clearInterval(timerInterval);
                startStopBtn.innerHTML = "▷ START";
                startStopBtn.style.backgroundColor = "var(--primary-color)";
                resetBtn.style.display = "block"; // Show reset when paused
            } else {
                // Start Timer
                timerInterval = setInterval(() => {
                    totalSeconds++;
                    updateDisplay();
                }, 1000);
                startStopBtn.innerHTML = "⏸ STOP";
                startStopBtn.style.backgroundColor = "var(--error-color)"; // Red for stop to make it clear
                resetBtn.style.display = "none";
            }
            isRunning = !isRunning;
        }

        function resetTimer() {
            clearInterval(timerInterval);
            totalSeconds = 0;
            isRunning = false;
            updateDisplay();
            startStopBtn.innerHTML = "▷ START";
            startStopBtn.style.backgroundColor = "var(--primary-color)";
            resetBtn.style.display = "none";
        }

        startStopBtn.addEventListener('click', toggleTimer);
        resetBtn.addEventListener('click', resetTimer);
    </script>
</body>
</html>
